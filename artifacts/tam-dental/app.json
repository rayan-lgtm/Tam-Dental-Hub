{
  "expo": {
    "name": "TAM Dental",
    "slug": "tam-dental",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "tam-dental",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A5F7A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "sa.tamdental.patient"
    },
    "android": {
      "package": "sa.tamdental.patient"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "TAM Dental needs location access to enable clinic check-in when you arrive."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
